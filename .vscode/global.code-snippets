  "useState Hook": {
    "scope": "javascriptreact,typescriptreact",
    "prefix": "usf",
    "body": [
      "const [${1:state}, set${1/(.*)/${1:/capitalize}/}] = useState(${2:initialValue});",
    ],
    "description": "useState with automatic CamelCase and initial value placeholder",
  },
  "setState": {
    "scope": "javascriptreact,typescriptreact",
    "prefix": "ss",
    "body": ["this.setState({ ${1:key}: ${2:value} });"],
    "description": "Standard this.setState",
  },
  "Functional setState": {
    "scope": "javascriptreact,typescriptreact",
    "prefix": "ssf",
    "body": [
      "this.setState((prevState) => ({",
      "  ...prevState,",
      "  ${1:key}: ${2:value}",
      "}));",
    ],
    "description": "Functional setState with object spreading",
  },
  "React Class Component": {
