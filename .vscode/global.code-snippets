  "React Context Provider": {
    "scope": "typescriptreact",
    "prefix": "rcpt",
    "body": [
      "import { createContext } from 'react';",
      "",
      "type ${1:name/(.*)/${1:/capitalize}/}ContextProviderProps = {",
      "\tchildren: React.ReactNode;",
      "};",
      "",
      "type ${1:name/(.*)/${1:/capitalize}/}ContextType = {",
      "\t$2",
      "};",
      "",
      "export const ${1:name/(.*)/${1:/capitalize}/}Context = createContext({} as ${1:name/(.*)/${1:/capitalize}/}ContextType);",
      "",
      "export const ${1:name/(.*)/${1:/capitalize}/}ContextProvider = ({ children }: ${1:name/(.*)/${1:/capitalize}/}ContextProviderProps) => {",
      "\treturn (",
      "\t\t<${1:name/(.*)/${1:/capitalize}/}Context.Provider",
      "\t\t\tvalue={{",
      "\t\t\t\t$3",
      "\t\t\t}}",
      "\t\t>",
      "\t\t\t{children}",
      "\t\t</${1:name/(.*)/${1:/capitalize}/}Context.Provider>",
      "\t);",
      "};",
    ],
    "description": "Declare a new Context Provider with TypeScript types and PascalCase naming.",
  },
