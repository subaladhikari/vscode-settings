{
  // Accessibility settings
  "accessibility.openChatEditedFiles": true,
  // Breadcrumbs settings
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  // Chat settings
  "chat.editor.fontSize": 12,
  "chat.fontSize": 14,
  "chat.notifyWindowOnResponseReceived": "off",
  "chat.viewSessions.orientation": "stacked",
  // CSS settings
  "css.validate": false,
  "css.format.spaceAroundSelectorSeparator": true,
  // Diff-Editor settings
  "diffEditor.ignoreTrimWhitespace": false,
  // Editor settings
  "editor.acceptSuggestionOnEnter": "on",
  "editor.accessibilitySupport": "off",
  "editor.autoIndent": "none",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.organizeImports": "never",
  },
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.defaultFormatter": null,
  "editor.detectIndentation": true,
  "editor.find.addExtraSpaceOnTop": false,
  "editor.fontFamily": "'Brass Mono Code', 'Brass Mono', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 18,
  "editor.fontWeight": "normal",
  "editor.formatOnPaste": false,
  "editor.formatOnSave": false,
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": "active",
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.indentation": true,
  "editor.hover.enabled": "on",
  "editor.inlineSuggest.edits.showCollapsed": true,
  "editor.inlineSuggest.enabled": true,
  "editor.letterSpacing": 0.25,
  "editor.lightbulb.enabled": "off",
  "editor.lineHeight": 28,
  "editor.linkedEditing": true,
  "editor.matchBrackets": "never",
  "editor.minimap.autohide": "mouseover",
  "editor.minimap.enabled": false,
  "editor.minimap.showSlider": "always",
  "editor.overviewRulerBorder": false,
  "editor.occurrencesHighlightDelay": 0,
  "editor.parameterHints.enabled": false,
  "editor.quickSuggestions": {
    "comments": "off",
    "other": "on",
    "strings": "on",
  },
  "editor.quickSuggestionsDelay": 0,
  "editor.renderWhitespace": "all",
  "editor.semanticHighlighting.enabled": true,
  "editor.snippetSuggestions": "top",
  "editor.stickyScroll.enabled": false,
  "editor.suggest.filterGraceful": false,
  "editor.suggest.preview": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggestFontSize": 16,
  "editor.suggestLineHeight": 24,
  "editor.suggestOnTriggerCharacters": true,
  "editor.suggestSelection": "recentlyUsed",
  "editor.tabCompletion": "on",
  "editor.tabSize": 2,
  "editor.trimAutoWhitespace": false,
  "editor.unicodeHighlight.allowedLocales": {
    "cs": true,
  },
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.wordBasedSuggestions": "off",
  "editor.wordWrap": "on",
  "editor.tokenColorCustomizations": {
    "[Tokyo Night]": {
      "textMateRules": [
        {
          "name": "Base comments (all comment types)",
          "scope": [
            "comment",
            "comment.line",
            "comment.block",
            "comment.block.documentation",
            "punctuation.definition.comment"
          ],
          "settings": {
            "fontStyle": "italic",
            "foreground": "#646E9C"
          }
        },
        {
          "name": "JSDoc / documentation types and keywords",
          "scope": [
            "comment.block.documentation storage.type.class",
            "comment.block.documentation keyword",
            "comment.block.documentation entity.name.type",
            "storage.type.class.jsdoc",
            "variable.other.jsdoc"
          ],
          "settings": {
            "foreground": "#bb9af7"
          }
        },
        {
          "name": "JSDoc instance/type annotations",
          "scope": [
            "comment.block.documentation entity.name.type.instance",
            "entity.name.type.instance.jsdoc"
          ],
          "settings": {
            "foreground": "#73daca",
            "fontStyle": "italic"
          }
        },
        {
          "name": "Control keywords (code, NOT comments)",
          "scope": [
            "keyword.control.conditional",
            "keyword.control.switch",
            "keyword.control.flow"
          ],
          "settings": {
            "foreground": "#e0af68"
          }
        }
      ]
    }
  },
  // Emmet settings
  "emmet.excludeLanguages": ["markdown"],
  "emmet.includeLanguages": {
    "liquid": "html",
    "css": "css",
    "scss": "css",
    "postcss": "css",
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
  },
  "emmet.showExpandedAbbreviation": "always",
  "emmet.showAbbreviationSuggestions": true,
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.triggerExpansionOnTab": true,
  // Explorer settings
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  // Extensions settings
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "extensions.ignoreRecommendations": true,
  // Files settings
  "files.associations": {
    "*.css": "tailwindcss",
    "*.liquid": "liquid",
    ".env*": "dotenv",
    "*.tst": "typescript",
    "**/*.conversation.json": "jsonc",
  },
  "files.autoSave": "off",
  "files.defaultLanguage": "${activeEditorLanguage}",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.coverage": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.svn": true,
    "**/CVS": true,
    ".git": true,
    ".build": true,
    ".history": true,
    ".profile-oss": true,
    "vendor": true,
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.readonlyInclude": {
    "**/node_modules/**/*.*": true,
    "**/yarn.lock": true,
    "**/package-lock.json": true,
    "**/Cargo.lock": true,
    "out/**": true,
    "out-build/**": true,
    "out-vscode/**": true,
    "out-vscode-reh/**": true,
    "extensions/**/dist/**": true,
    "extensions/**/out/**": true,
    "extensions/terminal-suggest/src/completions/upstream/**": true,
    "test/smoke/out/**": true,
    "test/automation/out/**": true,
    "src/vs/platform/agentHost/common/state/protocol/**": true,
    "test/integration/browser/out/**": true,
    // "src/vs/sessions/**": true
  },
  // Git settings
  "git.branchProtection": ["main", "release/*"],
  "git.branchProtectionPrompt": "alwaysCommit",
  "git.branchRandomName.enable": true,
  "git.confirmSync": false,
  "git.diagnosticsCommitHook.enabled": true,
  "git.diagnosticsCommitHook.sources": {
    "*": "error",
    "ts": "warning",
    "eslint": "warning",
  },
  "git.enableSmartCommit": true,
  "git.ignoreLimitWarning": true,
  "git.openRepositoryInParentFolders": "always",
  "git.pullBeforeCheckout": true,
  "git.terminalAuthentication": false,
  // GitHub Copilot
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.includeDocumentation": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  // Gutter Preview settings
  "gutterpreview.currentColorForSVG": "black",
  "gutterpreview.imagePreviewMaxHeight": 25,
  "gutterpreview.imagePreviewMaxWidth": 25,
  // HTML settings
  "html.format.enable": false,
  "html.format.indentInnerHtml": true,
  "html.format.preserveNewLines": true,
  "html.format.wrapAttributes": "force-expand-multiline",
  "html.format.wrapLineLength": 100,
  "html.validate.scripts": false,
  "html.validate.styles": false,
  // Inline Chat settings
  "inlineChat.defaultModel": "GPT-5 mini (copilot)",
  // Js/Ts settings
  "js/ts.experimental.useTsgo": true,
  "js/ts.validate.enabled": false,
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  // JSON settings
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true,
  },
  // Search settings
  "search.exclude": {
    "**/.git": true,
    "**/.github": true,
    "**/.next": true,
    "**/.output": true,
    "**/.pnpm": true,
    "**/.vscode": true,
    "**/.yarn": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/logs": true,
    "**/node_modules": true,
    "**/out/**": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/tmp": true,
    "**/vendor": true,
    "**/yarn.lock": true,
    ".build/**": true,
    "cli/target/**": true,
  },
  "search.useIgnoreFiles": false,
  // General settings
  "security.workspace.trust.untrustedFiles": "open",
  // Terminal settings
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.fontFamily": "'MesloLGS Nerd Font Mono', monospace",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.initialHint": false,
  "terminal.integrated.lineHeight": 1.25,
  "terminal.integrated.stickyScroll.enabled": false,
  // General settings
  "window.confirmSaveUntitledWorkspace": false,
  "window.newWindowProfile": "Default",
  // Workbench settings
  "workbench.browser.openLocalhostLinks": false,
  "workbench.colorTheme": "Tokyo Night",
  "workbench.colorCustomizations": {
    "[Tokyo Night]": {
      "panelTitle.border": "#29355a",
    },
  },
  "workbench.editor.defaultBinaryEditor": "default",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editor.useModal": "off",
  "workbench.editorAssociations": {
    "*.svg": "default",
    "*.copilotmd": "vscode.markdown.preview.editor",
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "material-product-icons",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.secondarySideBar.showLabels": false,
  "workbench.tips.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.indent": 8,
  "workbench.tree.renderIndentGuides": "always",

  // --- Extension Settings ---
  // Editor config
  "editorconfig.generateAuto": false,
  // Highlight matching tags
  "highlight-matching-tag.styles": {
    "opening": {
      "left": {
        "custom": {
          "borderWidth": "0 0 0 2px",
          "borderStyle": "solid",
          "borderColor": "yellow",
          "borderRadius": "4px",
          "overviewRulerColor": "white",
        },
      },
      "right": {
        "custom": {
          "borderWidth": "0 2px 0 0",
          "borderStyle": "solid",
          "borderColor": "yellow",
          "borderRadius": "4px",
          "overviewRulerColor": "white",
        },
      }
    },
  },
  // Import Cost
  "importCost.largePackageDarkColor": "#EE4458",
  "importCost.largePackageLightColor": "#EE4458",
  "importCost.mediumPackageDarkColor": "#FDE047",
  "importCost.mediumPackageLightColor": "#FDE047",
  "importCost.smallPackageDarkColor": "#22C55E",
  "importCost.smallPackageLightColor": "#22C55E",
  // Live Preview settings
  "livePreview.useIntegratedBrowser": true,
  // Live Server
  "liveServer.settings.donotShowInfoMsg": true,
  // Material Icon Theme
  "material-icon-theme.folders.associations": {
    "ui": "Theme",
  },
  // Package JSON Upgrade
  "package-json-upgrade.majorUpgradeColorOverwrite": "#EE4458",
  "package-json-upgrade.minorUpgradeColorOverwrite": "#FDE047",
  "package-json-upgrade.patchUpgradeColorOverwrite": "#22C55E",
  // Project Manager settings
  "projectManager.git.baseFolders": ["C:\\Users\\subal\\Code"],
  // Tailwind CSS
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.includeLanguages": {
    "plaintext": "html",
  },
  // Thunder Client
  "thunder-client.requestLayout": "Top/Bottom",

  // --- Formatter & Linter Settings ---
  // Biome Extension Settings
  "biome.enabled": false,
  "biome.suggestInstallingGlobally": false,
  // OXC Extension Settings
  "oxc.enable": false,
  "oxc.enable.oxfmt": false,
  "oxc.enable.oxlint": false,
  // ESLint Extension Settings
  "eslint.enable": false,
  "eslint.codeActionsOnSave.mode": "problems",
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml"
  ],
  // Prettier Extension Settings
  "prettier.enable": true,
  "prettier.arrowParens": "always",
  "prettier.bracketSameLine": false,
  "prettier.bracketSpacing": true,
  "prettier.embeddedLanguageFormatting": "auto",
  "prettier.endOfLine": "lf",
  "prettier.experimentalOperatorPosition": "start",
  "prettier.experimentalTernaries": true,
  "prettier.htmlWhitespaceSensitivity": "css",
  "prettier.insertPragma": false,
  "prettier.jsxSingleQuote": false,
  "prettier.objectWrap": "preserve",
  "prettier.printWidth": 100,
  "prettier.proseWrap": "always",
  "prettier.quoteProps": "as-needed",
  "prettier.requirePragma": false,
  "prettier.semi": true,
  "prettier.singleAttributePerLine": true,
  "prettier.singleQuote": true,
  "prettier.tabWidth": 2,
  "prettier.trailingComma": "all",
  "prettier.useTabs": false,
  "prettier.vueIndentScriptAndStyle": false,

  // --- Language Specific Settings ---
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css][scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json][jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript][javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript][typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
}
