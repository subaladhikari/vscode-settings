{
  // Breadcrumbs settings
  "breadcrumbs.enabled": true,
  "breadcrumbs.filePath": "on",
  // Chat settings
  "chat.viewSessions.orientation": "stacked",
  // CSS settings
  "css.validate": false,
  "css.format.spaceAroundSelectorSeparator": true,
  // Diff-Editor settings
  "diffEditor.ignoreTrimWhitespace": false,
  // Editor settings
  "editor.acceptSuggestionOnEnter": "on",
  "editor.accessibilitySupport": "off",
  "editor.autoIndent": "none",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.biome": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.prettier": "explicit",
    "source.fixAll.markdownlint": "explicit",
    "source.organizeImports": "never",
    "source.organizeImports.biome": "explicit",
    "source.organizeImports.eslint": "explicit"
  },
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorStyle": "line",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.find.addExtraSpaceOnTop": false,
  "editor.fontFamily": "'Brass Mono Code', 'Brass Mono', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 18,
  "editor.fontWeight": "normal",
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "editor.guides.bracketPairs": "active",
  "editor.guides.bracketPairsHorizontal": "active",
  "editor.guides.highlightActiveIndentation": true,
  "editor.guides.indentation": true,
  "editor.hover.enabled": "on",
  "editor.hover.sticky": false,
  "editor.inlineSuggest.edits.showCollapsed": true,
  "editor.inlineSuggest.enabled": true,
  "editor.letterSpacing": 0.25,
  "editor.lightbulb.enabled": "off",
  "editor.lineHeight": 27,
  "editor.linkedEditing": true,
  "editor.matchBrackets": "never",
  "editor.minimap.autohide": "mouseover",
  "editor.overviewRulerBorder": false,
  "editor.occurrencesHighlightDelay": 0,
  "editor.parameterHints.enabled": false,
  "editor.quickSuggestions": {
    "comments": "off",
    "other": "on",
    "strings": "on"
  },
  "editor.renderWhitespace": "all",
  "editor.semanticHighlighting.enabled": true,
  "editor.stickyScroll.enabled": false,
  "editor.suggest.filterGraceful": false,
  "editor.suggest.localityBonus": false,
  "editor.suggest.preview": true,
  "editor.suggest.showConstants": true,
  "editor.suggest.showFunctions": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.suggestFontSize": 22,
  "editor.suggestLineHeight": 30,
  "editor.suggestSelection": "first",
  "editor.tabCompletion": "onlySnippets",
  "editor.tabSize": 2,
  "editor.trimAutoWhitespace": false,
  "editor.unicodeHighlight.allowedLocales": {
    "cs": true
  },
  "editor.wordBasedSuggestions": "off",
  "editor.wordWrap": "on",
  "editor.tokenColorCustomizations": {
    "[Tokyo Night]": {
      "textMateRules": [
        {
          "scope": [
            "comment",
            "comment.block.documentation",
            "comment.block.documentation.js",
            "comment.line.double-slash.js",
            "storage.type.class.jsdoc",
            "entity.name.type.instance.jsdoc",
            "variable.other.jsdoc",
            "punctuation.definition.comment",
            "punctuation.definition.comment.begin.documentation",
            "punctuation.definition.comment.end.documentation"
          ],
          "settings": {
            "fontStyle": "italic",
            "foreground": "#646E9C"
          }
        },
        {
          "scope": [
            "comment keyword.codetag.notation",
            "comment.block.documentation keyword",
            "comment.block.documentation storage.type.class"
          ],
          "settings": {
            "foreground": "#bb9af7"
          }
        },
        {
          "scope": ["comment.block.documentation entity.name.type.instance"],
          "settings": {
            "fontStyle": "italic",
            "foreground": "#73daca"
          }
        },
        {
          "scope": [
            "comment.block.documentation entity.name.type punctuation.definition.bracket"
          ],
          "settings": {
            "foreground": "#bb9af7"
          }
        },
        {
          "scope": ["comment.block.documentation variable"],
          "settings": {
            "fontStyle": "italic",
            "foreground": "#e0af68"
          }
        }
      ]
    }
  },
  // Emmet settings
  "emmet.excludeLanguages": ["markdown"],
  "emmet.includeLanguages": {
    "liquid": "html",
    "css": "css",
    "scss": "css",
    "postcss": "css",
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "emmet.showExpandedAbbreviation": "never",
  "emmet.showSuggestionsAsSnippets": true,
  "emmet.syntaxProfiles": {
    "javascript": "html, css, jsx"
  },
  "emmet.triggerExpansionOnTab": true,
  // Explorer settings
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  // Extensions settings
  "extensions.autoUpdate": "onlyEnabledExtensions",
  "extensions.ignoreRecommendations": true,
  // Files settings
  "files.associations": {
    "*.css": "tailwindcss",
    "*.liquid": "liquid",
    ".env*": "dotenv",
    "*.tst": "typescript",
    "**/*.conversation.json": "jsonc"
  },
  "files.autoSave": "off",
  "files.defaultLanguage": "${activeEditorLanguage}",
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.coverage": true,
    "**/.git": true,
    "**/.hg": true,
    "**/.svn": true,
    "**/CVS": true,
    ".git": true,
    ".build": true,
    ".history": true,
    ".profile-oss": true,
    "vendor": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.readonlyInclude": {
    "**/node_modules/**/*.*": true,
    "**/yarn.lock": true,
    "**/package-lock.json": true,
    "**/Cargo.lock": true,
    "out/**": true,
    "out-build/**": true,
    "out-vscode/**": true,
    "out-vscode-reh/**": true,
    "extensions/**/dist/**": true,
    "extensions/**/out/**": true,
    "extensions/terminal-suggest/src/completions/upstream/**": true,
    "test/smoke/out/**": true,
    "test/automation/out/**": true,
    "src/vs/platform/agentHost/common/state/protocol/**": true,
    "test/integration/browser/out/**": true
    // "src/vs/sessions/**": true
  },
  // Git settings
  "git.branchProtection": ["main", "release/*"],
  "git.branchProtectionPrompt": "alwaysCommit",
  "git.branchRandomName.enable": true,
  "git.confirmSync": false,
  "git.diagnosticsCommitHook.enabled": true,
  "git.diagnosticsCommitHook.sources": {
    "*": "error",
    "ts": "warning",
    "eslint": "warning"
  },
  "git.enableSmartCommit": true,
  "git.ignoreLimitWarning": true,
  "git.mergeEditor": true,
  "git.openRepositoryInParentFolders": "always",
  "git.pullBeforeCheckout": true,
  // GitHub Copilot
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.includeDocumentation": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  // Gutter Preview settings
  "gutterpreview.currentColorForSVG": "black",
  // HTML settings
  "html.format.enable": false,
  "html.format.indentInnerHtml": true,
  "html.format.preserveNewLines": true,
  "html.format.wrapAttributes": "force-expand-multiline",
  "html.format.wrapLineLength": 80,
  "html.validate.scripts": false,
  "html.validate.styles": false,
  // Inline Chat settings
  "inlineChat.enableV2": true,
  "inlineChat.affordance": "editor",
  // JavaScript settings
  "javascript.validate.enable": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  // JSON settings
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true
  },
  // Search settings
  "search.exclude": {
    "**/.git": true,
    "**/.github": true,
    "**/.next": true,
    "**/.output": true,
    "**/.pnpm": true,
    "**/.vscode": true,
    "**/.yarn": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/logs": true,
    "**/node_modules": true,
    "**/out/**": true,
    "**/package-lock.json": true,
    "**/pnpm-lock.yaml": true,
    "**/tmp": true,
    "**/vendor": true,
    "**/yarn.lock": true,
    ".build/**": true,
    "cli/target/**": true
  },
  // General settings
  "security.workspace.trust.untrustedFiles": "open",
  // Terminal settings
  "terminal.integrated.cursorBlinking": false,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.fontFamily": "'MesloLGS Nerd Font Mono', monospace",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.fontWeight": "normal",
  "terminal.integrated.initialHint": false,
  "terminal.integrated.lineHeight": 1.25,
  "terminal.integrated.profiles.windows": {
    "Command Prompt": {
      "args": [],
      "icon": "terminal-cmd",
      "path": [
        "${env:windir}\\Sysnative\\cmd.exe",
        "${env:windir}\\System32\\cmd.exe"
      ]
    },
    "Git Bash": {
      "args": ["--login", "-i"],
      "path": "C:\\Program Files\\Git\\bin\\bash.exe"
    },
    "PowerShell": {
      "icon": "terminal-powershell",
      "source": "PowerShell"
    }
  },
  "terminal.integrated.stickyScroll.enabled": false,
  // TypeScript settings
  "typescript.format.enable": true,
  "typescript.experimental.useTsgo": true,
  "typescript.format.insertSpaceAfterCommaDelimiter": true,
  "typescript.format.insertSpaceAfterSemicolonInForStatements": true,
  "typescript.format.insertSpaceBeforeAndAfterBinaryOperators": true,
  "typescript.format.insertSpaceAfterKeywordsInControlFlowStatements": true,
  "typescript.format.insertSpaceAfterFunctionKeywordForAnonymousFunctions": true,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyParenthesis": false,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": false,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": false,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": true,
  "typescript.format.insertSpaceBeforeFunctionParenthesis": false,
  "typescript.format.placeOpenBraceOnNewLineForFunctions": false,
  "typescript.format.placeOpenBraceOnNewLineForControlBlocks": false,
  "typescript.preferences.quoteStyle": "double",
  // General settings
  "update.mode": "none",
  // General settings
  "window.confirmSaveUntitledWorkspace": false,
  "window.newWindowProfile": "Default",
  // Workbench settings
  "workbench.browser.openLocalhostLinks": false,
  "workbench.colorTheme": "Tokyo Night",
  "workbench.colorCustomizations": {
    "[Tokyo Night]": {
      "editorIndentGuide.activeBackground1": "#505362",
      "editorIndentGuide.activeBackground2": "#5b5e6c",
      "editorIndentGuide.activeBackground3": "#666976",
      "editorIndentGuide.activeBackground4": "#717380",
      "editorIndentGuide.activeBackground5": "#717380",
      "editorIndentGuide.activeBackground6": "#717380",
      "panelTitle.border": "#29355a"
    }
  },
  "workbench.editor.defaultBinaryEditor": "default",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.editorAssociations": {
    "*.svg": "default",
    "*.copilotmd": "vscode.markdown.preview.editor"
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.secondarySideBar.showLabels": false,
  "workbench.sideBar.location": "right",
  "workbench.tips.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.indent": 8,
  "workbench.tree.renderIndentGuides": "always",

  // --- Extension Settings ---
  // Editor config
  "editorconfig.generateAuto": false,
  // Highlight matching tags
  "highlight-matching-tag.styles": {
    "opening": {
      "left": {
        "custom": {
          "borderWidth": "0 0 0 2px",
          "borderStyle": "solid",
          "borderColor": "yellow",
          "borderRadius": "4px",
          "overviewRulerColor": "white"
        }
      },
      "right": {
        "custom": {
          "borderWidth": "0 2px 0 0",
          "borderStyle": "solid",
          "borderColor": "yellow",
          "borderRadius": "4px",
          "overviewRulerColor": "white"
        }
      }
    }
  },
  // Import Cost
  "importCost.largePackageDarkColor": "#ee4458",
  "importCost.largePackageLightColor": "#ee4458",
  "importCost.mediumPackageDarkColor": "#f05769",
  "importCost.mediumPackageLightColor": "#f05769",
  "importCost.smallPackageDarkColor": "#f16979",
  "importCost.smallPackageLightColor": "#f16979",
  // Live Preview settings
  "livePreview.useIntegratedBrowser": true,
  // Material Icon Theme
  "material-icon-theme.folders.associations": {
    "ui": "Theme"
  },
  // Package JSON Upgrade
  "package-json-upgrade.majorUpgradeColorOverwrite": "#ee4458",
  "package-json-upgrade.minorUpgradeColorOverwrite": "#f16979",
  "package-json-upgrade.patchUpgradeColorOverwrite": "#f05769",
  // Project Manager settings
  "projectManager.git.baseFolders": ["C:\\Users\\subal\\Code"],
  // Tailwind CSS
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.includeLanguages": {
    "plaintext": "html"
  },
  // Thunder Client
  "thunder-client.requestLayout": "Top/Bottom",

  // --- Formatter & Linter Settings ---
  // Biome Extension Settings
  "biome.enabled": false,
  "biome.requireConfiguration": true,
  "biome.suggestInstallingGlobally": false,
  // ESLint Extension Settings
  "eslint.enable": false,
  "eslint.codeActionsOnSave.mode": "problems",
  "eslint.run": "onSave",
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "eslint.useFlatConfig": true,
  // Prettier Extension Settings
  "prettier.enable": true,
  "prettier.arrowParens": "always",
  "prettier.bracketSameLine": false,
  "prettier.bracketSpacing": true,
  "prettier.embeddedLanguageFormatting": "auto",
  "prettier.endOfLine": "lf",
  "prettier.experimentalOperatorPosition": "start",
  "prettier.experimentalTernaries": true,
  "prettier.htmlWhitespaceSensitivity": "css",
  "prettier.insertPragma": false,
  "prettier.jsxSingleQuote": false,
  "prettier.objectWrap": "preserve",
  "prettier.printWidth": 80,
  "prettier.proseWrap": "always",
  "prettier.quoteProps": "as-needed",
  "prettier.requirePragma": false,
  "prettier.semi": true,
  "prettier.singleAttributePerLine": true,
  "prettier.singleQuote": true,
  "prettier.tabWidth": 2,
  "prettier.trailingComma": "all",
  "prettier.useTabs": false,
  "prettier.vueIndentScriptAndStyle": false,

  // --- Language Specific Settings ---
  "[javascript][javascriptreact]": {
    "editor.snippetSuggestions": "top",
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript][typescriptreact]": {
    "editor.snippetSuggestions": "top",
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json][jsonc][plaintext][markdown]": {
    "files.insertFinalNewline": false
  }
}
